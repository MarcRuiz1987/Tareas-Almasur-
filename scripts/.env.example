# Plantilla de variables para crear-borrador.py (Microsoft Graph).
# NO commitear el archivo .env real. En Claude Code web, cargar estos valores como
# SECRETOS del environment (no como archivo). Aquí solo se documentan los nombres.

# Microsoft Entra ID (Azure AD) — registro de aplicación con permiso Mail.ReadWrite
# (application) + consentimiento de administrador. Ver README.
TENANT_ID=
CLIENT_ID=
CLIENT_SECRET=

# Buzón sobre el que se crea el borrador (correo del usuario).
MAILBOX=Marcelo.ruiz@ialmasur.cl
