# Claves de API de la v3 — copia este archivo a .env y completa sólo lo que uses.
# NO commitees el .env real.

# Google Places API (resolver sitio web / teléfono / dirección) — Google Cloud Console.
GOOGLE_PLACES_API_KEY=

# Hunter.io (descubrir contactos por dominio) — hunter.io/api-keys
HUNTER_API_KEY=

# FullEnrich (verificar email + teléfono, waterfall) — app.fullenrich.com
FULLENRICH_API_KEY=

# Proveedor de RUT chileno (nombre de empresa → RUT). Configurable: usa {q} como
# marcador de la consulta. Ejemplos de servicios: SimpleAPI, Boostr, LibreDTE.
#   RUT_API_URL=https://api.tu-proveedor.cl/empresas?nombre={q}
#   RUT_API_KEY=...                 # opcional (se envía como Bearer)
#   RUT_API_JSON_PATH=data.0.rut    # ruta con puntos al RUT dentro del JSON
RUT_API_URL=
RUT_API_KEY=
RUT_API_JSON_PATH=rut
