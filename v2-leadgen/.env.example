# Claves de API de la v2 — copia este archivo a .env y complétalo.
# NO commitees el .env real.

# Google Places API (descubrimiento de empresas) — Google Cloud Console.
GOOGLE_PLACES_API_KEY=

# Hunter.io (descubrir contactos por dominio) — hunter.io/api-keys
HUNTER_API_KEY=

# FullEnrich (enriquecer email verificado + teléfono, waterfall) — app.fullenrich.com
FULLENRICH_API_KEY=

# Anthropic / Claude (descripción y calificación ICP) — console.anthropic.com
ANTHROPIC_API_KEY=
